{
  "id": "emma.plugin.test",
  "name": "EMMA Test Plugin",
  "version": "0.1.0",
  "description": "Local test plugin that provides paged and video content via gRPC.",
  "author": "EMMA",
  "protocol": "grpc",
  "runtime": {
    "minHostVersion": "1.0.0"
  },
  "mediaTypes": [
    "paged"
  ],
  "thumbnail": {
    "aspectRatio": 0.7,
    "fit": "cover",
    "width": 256,
    "height": 384
  },
  "capabilities": {
    "network": [
      "https"
    ],
    "fileSystem": [],
    "cache": false,
    "cpuBudgetMs": 250,
    "memoryMb": 512
  },
  "permissions": {
    "domains": [
      "api.mangadex.org",
      "uploads.mangadex.org"
    ],
    "paths": []
  }
}
