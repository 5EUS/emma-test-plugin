{
  "id": "emma.plugin.test",
  "name": "EMMA Test Plugin",
  "version": "0.1.0",
  "description": "Local test plugin that provides paged and video content via gRPC.",
  "author": "EMMA",
  "protocol": "grpc",
  "runtime": {
    "minHostVersion": "1.0.0",
    "wasmHostBridge": {
      "http": {
        "search": {
          "method": "GET",
          "urlTemplate": "https://api.mangadex.org/manga?title={arg0}&limit=20&contentRating[]=safe&contentRating[]=suggestive&includes[]=cover_art"
        },
        "chapters": {
          "method": "GET",
          "urlTemplate": "https://api.mangadex.org/manga/{arg0}/feed?limit=100&order[chapter]=asc&translatedLanguage[]=en"
        },
        "page": {
          "method": "GET",
          "urlTemplate": "https://api.mangadex.org/at-home/server/{arg1}"
        }
      }
    }
  },
  "mediaTypes": [
    "paged"
  ],
  "capabilities": {
    "network": [
      "https"
    ],
    "fileSystem": [],
    "cache": false,
    "cpuBudgetMs": 250,
    "memoryMb": 512
  },
  "permissions": {
    "domains": [
      "api.mangadex.org",
      "uploads.mangadex.org"
    ],
    "paths": []
  }
}
