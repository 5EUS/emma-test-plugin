<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <EmmaSdkVersion Condition="'$(EmmaSdkVersion)' == '' and '$(EMMA_SDK_VERSION)' != ''">$(EMMA_SDK_VERSION)</EmmaSdkVersion>
    <EmmaSdkVersion Condition="'$(EmmaSdkVersion)' == ''">0.6.8</EmmaSdkVersion>
    <EmmaSdkRoot Condition="'$(EmmaSdkRoot)' == '' and Exists('EMMA/src/EMMA.Plugin.Common/EMMA.Plugin.Common.csproj')">EMMA</EmmaSdkRoot>
    <EmmaSdkRoot Condition="'$(EmmaSdkRoot)' == '' and Exists('../EMMA/src/EMMA.Plugin.Common/EMMA.Plugin.Common.csproj')">../EMMA</EmmaSdkRoot>
    <UseLocalEmmaSdk Condition="'$(UseLocalEmmaSdk)' == '' and '$(EmmaSdkRoot)' != ''">true</UseLocalEmmaSdk>
    <UseLocalEmmaSdk Condition="'$(UseLocalEmmaSdk)' == ''">false</UseLocalEmmaSdk>
    <RestoreConfigFile Condition="'$(UseLocalEmmaSdk)' == 'true' and '$(RestoreConfigFile)' == '' and Exists('$(EmmaSdkRoot)/nuget.config')">$(EmmaSdkRoot)/nuget.config</RestoreConfigFile>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseLocalEmmaSdk)' == 'true'">
    <ProjectReference Include="$(EmmaSdkRoot)/src/EMMA.Plugin.Common/EMMA.Plugin.Common.csproj" />
    <ProjectReference Include="$(EmmaSdkRoot)/src/EMMA.Plugin.Common.Generators/EMMA.Plugin.Common.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseLocalEmmaSdk)' != 'true'">
    <PackageReference Include="EMMA.Plugin.Common" Version="$(EmmaSdkVersion)" />
    <PackageReference Include="EMMA.Plugin.Common.Generators" Version="$(EmmaSdkVersion)" PrivateAssets="all" />
  </ItemGroup>
</Project>